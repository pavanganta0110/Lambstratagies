# Lamb Strategy Environment Variables Template
# Copy this file to '.env.local' and populate with actual credentials.

# 1. Contact Form Email/API Integrations (Future Setup)
# e.g., SendGrid, Mailchimp, or direct webhook targets
CONTACT_FORM_WEBHOOK_URL=https://api.lambstrategy.com/v1/inbound-leads
CONTACT_NOTIFICATION_EMAIL=co-pilot@lambstrategy.com

# 2. OneRoom OS Credentials (Future Setup)
# e.g., Supabase or custom database connection string
NEXT_PUBLIC_ONEROOM_API_URL=https://api.oneroom.ai
NEXT_PUBLIC_ONEROOM_PROJECT_ID=lamb-strategy-oneroom-os

# 3. Next.js Configurations
PORT=3000
NODE_ENV=development

# 4. Resend Email Integration (Contact Form)
RESEND_API_KEY=your_resend_api_key_here
CONTACT_TO_EMAIL=claudia@lambstrategy.com
CONTACT_CC_EMAIL=elijah@lambstrategy.com
CONTACT_FROM_EMAIL=website@lambstrategy.com

